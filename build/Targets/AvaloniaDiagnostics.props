<Project>

    <PropertyGroup>
        <DefineConstants Condition="'$(EnableAvaloniaDiagnostics)' == 'True'">AVALONIA_DIAGNOSTICS;$(DefineConstants)</DefineConstants>
    </PropertyGroup>

    <ItemGroup Condition="'(EnableAvaloniaRc)' != 'true'">
        <PackageReference Include="Avalonia.Diagnostics" />
    </ItemGroup>

    <ItemGroup Condition="'(EnableAvaloniaRc)' == 'true'">
        <PackageReference Include="AvaloniaUI.DiagnosticsSupport" />
    </ItemGroup>

</Project>
