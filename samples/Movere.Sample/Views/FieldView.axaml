<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Movere.Sample.ViewModels"
             x:Class="Movere.Sample.Views.FieldView"
             x:DataType="vm:FieldViewModel">

    <TextBox
        PlaceholderText="{Binding Name}"
        Text="{Binding Value}" />

</UserControl>
